# Typesense Search — connection settings
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are ignored.
#
# Values defined here override the WordPress database options for the matching
# fields on the Connection tab. Those fields will be rendered read-only in the
# WordPress admin UI so they cannot accidentally be overwritten.
#
# The .env file must never be committed to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL to your Typesense server (required)
# Examples:
#   https://search.example.com
#   https://your-instance.typesense.net
#   http://localhost:8108
TYPESENSE_HOST=https://your-instance.typesense.net

# Optional: public host sent to the browser (useful behind a reverse proxy)
# Leave blank to fall back to TYPESENSE_HOST for front-end requests.
TYPESENSE_FRONTEND_HOST=

# Name of the Typesense collection to read from and write to (required)
TYPESENSE_COLLECTION=my-wordpress-site

# Admin (full-access) API key — used server-side only, never exposed publicly (required)
TYPESENSE_ADMIN_KEY=your-admin-api-key

# Search-only API key — passed to front-end JavaScript (required)
TYPESENSE_SEARCH_KEY=your-search-only-api-key
