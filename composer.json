{
    "name": "considbrs-webdev/typesense-search",
    "description": "Typesense Search Plugin for WordPress and Municipio",
    "type": "wordpress-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Considbrs-Webdev",
            "email": "webdev@considbrs.se"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "php-stubs/wp-cli-stubs": "^2.0",
        "phpunit/phpunit": "^9.6"
    },
    "suggest": {
        "helsingborg-stad/municipio": "^6.0.0"
    },
    "autoload": {
        "psr-4": {
            "TypesenseSearch\\": "source/php/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TypesenseSearch\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-text",
        "test:dox": "vendor/bin/phpunit --testdox"
    },
    "require": {
        "php": ">=8.3",
        "typesense/typesense-php": "^6.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "version": "1.4.1"
}
