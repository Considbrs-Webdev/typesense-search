msgid "Could not load statistics: %s"
msgstr "Kunde inte läsa in statistik: %s"

#: source/php/Admin/SettingsAjax.php:295
msgid "Post type is required."
msgstr "Inläggstyp krävs."

#: source/php/Admin/SettingsAjax.php:304
