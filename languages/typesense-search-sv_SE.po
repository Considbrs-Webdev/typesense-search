msgstr "Söknyckeln har inte åtkomst till samlingen \"%s\"."

#. translators: %s: error message
#: source/php/Admin/SettingsAjax.php:541
msgid "Search key check failed: %s"
msgstr "Kontroll av söknyckel misslyckades: %s"

#: source/php/Admin/SettingsAjax.php:576
msgid ""
"Host, admin key, and collection name must all be saved before a new search "
"key can be created."
msgstr ""
"Värd, admin-nyckel och samlingsnamn måste vara sparade innan en ny söknyckel "
"kan skapas."

#. translators: %s: error message
#: source/php/Admin/SettingsAjax.php:588
msgid "Could not create search key: %s"
msgstr "Kunde inte skapa söknyckel: %s"

#: source/php/Admin/SettingsAjax.php:598
msgid "New search key created and saved. The status checks should now pass."
msgstr "Ny söknyckel skapad och sparad. Statuskontrollerna borde nu passera."

#: source/php/Admin/SettingsAjax.php:623
msgid ""
"Host, admin key, and collection name must all be saved before the collection "
"can be created."
msgstr ""
"Värd, admin-nyckel och samlingsnamn måste vara sparade innan samlingen kan "
"skapas."

